# Set default behavior to handle line endings automatically
* text=auto eol=lf

# Explicitly declare text files to always use LF
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.pdf binary
